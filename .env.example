# =============================================================================
# Acme Industries Business Suite — Demo
#
# Copy to `.env` and adjust. Sensible defaults are baked into docker-compose.yml,
# so for a purely-local run you only really need DEMO_DOMAIN + HTTP_PORT. To
# expose it publicly you also need CLOUDFLARE_TUNNEL_TOKEN.
# =============================================================================

# Public base domain. Each app is served at <sub>.${DEMO_DOMAIN}; the portal at
# the apex. Must have DNS for the apex + a wildcard (*.DEMO_DOMAIN) on Cloudflare.
DEMO_DOMAIN=demo.haydennester.com

# Host port the Caddy proxy listens on (the tunnel + local smoke tests hit this).
HTTP_PORT=8080

# Cloudflare Tunnel token (Zero Trust > Networks > Tunnels). Required only for the
# `--profile tunnel` (public) run. Configure ingress in the CF dashboard:
#   demo.haydennester.com      -> http://caddy:80
#   *.demo.haydennester.com    -> http://caddy:80
CLOUDFLARE_TUNNEL_TOKEN=

# Shared SSO secret the portal uses to mint cross-app tokens (same value everywhere).
# Rotate for a real deployment.
PORTAL_SSO_SECRET=demo-sso-shared-secret

# Per-app JWT secrets (optional overrides; demo defaults exist in compose).
JWT_SECRET=demo-jwt-secret
JWT_SECRET_MOC=demo-jwt-secret-moc
JWT_SECRET_IT=demo-jwt-secret-it
JWT_SECRET_SHIPPING=demo-jwt-secret-shipping

# Demo mode stubs all external integrations (Entra/SSO -> role dropdown, SMTP ->
# stdout, Oracle/IQMS/AVEVA/UniFi syncs -> disabled, IQMS chat -> canned answers).
DEMO_MODE=true
