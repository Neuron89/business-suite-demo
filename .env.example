# =============================================================================
# Acme Industries Business Suite — Demo
#
# You do NOT need to set anything here. Every value has a working default
# baked into docker-compose.yml so the suite runs with `docker compose up`
# out of the box.
#
# This file exists only to document what's there in case you want to tweak
# something (e.g. change the SSO secret, switch ports, etc).
# =============================================================================

# Shared SSO secret used by Portal to mint cross-app tokens
PORTAL_SSO_SECRET=demo-sso-shared-secret-do-not-use-in-prod

# Postgres
POSTGRES_USER=demo
POSTGRES_PASSWORD=demo
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Set to "false" if you want to disable demo mode (requires real Azure SSO config)
DEMO_MODE=true
